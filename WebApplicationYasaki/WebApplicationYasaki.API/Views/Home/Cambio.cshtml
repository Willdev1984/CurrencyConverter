@{
    ViewData["Title"] = "Câmbio em Tempo Real";
}

<div class="container mt-5" style="max-width: 500px;">
    <div class="card shadow-sm border-primary">
        <div class="card-header bg-primary text-white text-center">
            <h3 class="mb-0"><i class="bi bi-currency-exchange me-2"></i>Câmbio do Dia</h3>
        </div>
        <div class="card-body text-center py-4">

            <div class="mb-4 text-start">
                <label for="seletorMoedas" class="form-label fw-bold text-muted">Selecione o Par de Moedas:</label>
                <select class="form-select" id="seletorMoedas" onchange="atualizarCambio()">
                    <option value="BRL-EUR" selected>1 Real Brasileiro (BRL) para Euro (EUR)</option>
                    <option value="USD-EUR">1 Dólar Americano (USD) para 1 Euro (EUR)</option>
                    <option value="EUR-USD">1 Euro (EUR) para 1 Dólar Americano (USD)</option>
                    <option value="EUR-BRL">1 Euro (EUR) para 1 Real Brasileiro (BRL)</option>
                    <option value="BRL-USD">1 Real Brasileiro (BRL) para 1 Dólar (USD)</option>
                    <option value="USD-BRL">1 Dólar (USD) para 1 Real Brasileiro (BRL)</option>
                </select>
            </div>

            <hr>

            <h5 class="text-muted mt-3" id="parMoedas">A carregar taxas...</h5>

            <div class="my-4">
                <span class="display-3 fw-bold text-success" id="valorCambio">0.0000</span>
                <span class="fs-4 text-success" id="moedaDestino"></span>
            </div>

            <div class="row text-muted mt-3">
                <div class="col-6 border-end">
                    <small>Máximo</small>
                    <p class="mb-0 fw-bold text-danger" id="maximo">0.0000</p>
                </div>
                <div class="col-6">
                    <small>Mínimo</small>
                    <p class="mb-0 fw-bold text-info" id="minimo">0.0000</p>
                </div>
            </div>

            <hr>
            <button class="btn btn-outline-primary" onclick="atualizarCambio()">
                <i class="bi bi-arrow-clockwise me-2"></i>Atualizar Agora
            </button>
        </div>
        <div class="card-footer text-muted text-center py-2" style="font-size: 0.8rem;">
            Última consulta: <span id="dataAtualizacao">-</span>
        </div>
    </div>
</div>

<script>
            async function atualizarCambio() {
        const seletor = document.getElementById('seletorMoedas');
        const parMoedasEl = document.getElementById('parMoedas');

        try {
            // 1. Mostra estado de carregamento
            parMoedasEl.innerText = "A carregar taxas...";

            const parSelecionado = seletor.value; // Ex: "USD-EUR"
            const [moedaOrigem, moedaDestino] = parSelecionado.split('-');

            // 2. Faz a chamada ao seu controller .NET
            const resposta = await fetch(`/api/Cambio/converter?de=${moedaOrigem}&para=${moedaDestino}`);

            if (resposta.status === 429) {
                throw new Error('Muitas requisições. Aguarde 1 minuto.');
            }

            if (!resposta.ok) {
                throw new Error('Falha ao obter cotação.');
            }

            const dados = await resposta.json();

            // 3. Define o símbolo da moeda de destino
            let simbolo = "R$";
            if (moedaDestino === "USD") simbolo = "$";
            if (moedaDestino === "EUR") simbolo = "€";

            // 4. Atualiza a Interface
            parMoedasEl.innerText = dados.nome || `${moedaOrigem} para ${moedaDestino}`;
            document.getElementById('valorCambio').innerText = Number(dados.taxaAtual).toFixed(4);
            document.getElementById('moedaDestino').innerText = simbolo;
            document.getElementById('maximo').innerText = Number(dados.ultimoMaximo).toFixed(4);
            document.getElementById('minimo').innerText = Number(dados.ultimoMinimo).toFixed(4);
            document.getElementById('dataAtualizacao').innerText = new Date(dados.dataConsulta).toLocaleTimeString('pt-PT');

        } catch (erro) {
            console.error("Erro capturado no JS:", erro);
            parMoedasEl.innerText = erro.message.includes('Muitas')
                ? "Limite de consultas excedido. Aguarde."
                : "Erro ao carregar cotações.";
        }
    }

    // Executa automaticamente ao carregar a página
    window.onload = atualizarCambio;
</script>