@model ClimaTemp.Models.PrevisaoViewModel



@{
    ViewData["Title"] = "Previsão do Tempo";
}


<div class="text-center mt-4">
    <h2>Previsão para 10 dias</h2>

    <!-- Formulário de Busca -->
    <form method="post" asp-action="Index" class="mt-4">
        <div class="input-group mb-3 w-50 mx-auto">
            <input type="text" name="cidade" class="form-control" placeholder="Digite o nome da cidade..." value="@Model.CidadePesquisada" required />
            <button class="btn btn-primary" type="submit">Buscar Previsão</button>
        </div>
    </form>

    <!-- Exibição de Erros -->
    @if (!string.IsNullOrEmpty(Model.MensagemErro))
    {
        <div class="alert alert-danger w-50 mx-auto">
            @Model.MensagemErro
        </div>
    }

    <!-- Exibição da Previsão -->
    @if (Model.Previsoes.Any())
    {
        <h4 class="mt-4">Resultados para: @Model.CidadePesquisada</h4>

        <table class="table table-striped table-bordered mt-3 w-75 mx-auto">
            <thead class="table-dark">
                <tr>
                    <th>Data</th>
                    <th>Clima</th>
                    <th>Temp. Máxima (°C)</th>
                    <th>Temp. Mínima (°C)</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var dia in Model.Previsoes)
                {
                    <tr>
                        <td>@dia.Data</td>
                        <!-- Nova Célula com a animação CSS -->
                        <td class="text-center align-middle">
                            <span class="clima-animado">@dia.IconeAnimado</span>
                        </td>
                        <td>@dia.TempMaxima</td>
                        <td>@dia.TempMinima</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>